# Nine Grid local runtime configuration example
NINE_GRID_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
NINE_GRID_DB_PATH=backend/data/nine_grid.sqlite3
NINE_GRID_TEMP_DIR=

# Docker Compose production-style local run usually uses:
# NINE_GRID_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
# NINE_GRID_DB_PATH=/data/nine_grid.sqlite3
# NINE_GRID_TEMP_DIR=/tmp/nine_grid_exports

# Nine Grid backend mail configuration example
NINE_GRID_SMTP_HOST=smtp.qq.com
NINE_GRID_SMTP_PORT=465
NINE_GRID_SMTP_USERNAME=your_mail@qq.com
NINE_GRID_SMTP_PASSWORD=your_smtp_authorization_code
NINE_GRID_MAIL_FROM=your_mail@qq.com
NINE_GRID_SMTP_USE_SSL=true
